# =============================================
# Azure AD / Microsoft Entra ID
# =============================================
# Client ID from Azure App Registration (see README for setup steps)
AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client Secret from Azure App Registration → Certificates & secrets
AZURE_AD_CLIENT_SECRET=your-client-secret-here

# Tenant ID — found on Azure AD Overview page
AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =============================================
# NextAuth
# =============================================
# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string

# The public URL where the app runs (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# =============================================
# App configuration
# =============================================
# Comma-separated Azure AD Object IDs of admin users
# (alternatively set role='admin' directly in the database)
ADMIN_USER_IDS=

# Absolute path to SQLite database file (defaults to ./data/passbokning.db)
DATABASE_PATH=./data/passbokning.db
