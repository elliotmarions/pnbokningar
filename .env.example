# =============================================
# Supabase (required)
# =============================================
# Project URL and anon key — Supabase dashboard → Project Settings → API.
# These are safe to expose to the browser (anon key is gated by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres connection string (the app talks to Postgres via the `postgres`
# library, not PostgREST). Use the TRANSACTION POOLER URL (port 6543) —
# Supabase dashboard → Project Settings → Database → Connection string → Transaction.
DATABASE_URL=postgres://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# =============================================
# Admin bootstrap (optional)
# =============================================
# Comma-separated Azure AD Object IDs (the user's id) that should be granted the
# 'admin' role automatically on login. Alternatively promote users in Admin → Chaufförer.
ADMIN_USER_IDS=

# =============================================
# Web Push / VAPID (required for notifications)
# =============================================
# Generate a key pair with: npm run gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# =============================================
# Cron (required in production)
# =============================================
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`.
# Also accepted as `?secret=` for manual runs. Generate any long random string.
CRON_SECRET=

# =============================================
# Partner integration (optional — only if syncing bookings to an external system)
# =============================================
# Inbound: partner authenticates to /api/integration/* with this bearer key.
INTEGRATION_API_KEY=
# Outbound: where we POST booking.confirmed / booking.cancelled webhooks, signed
# with INTEGRATION_WEBHOOK_SECRET. Leave blank to disable outbound webhooks.
INTEGRATION_WEBHOOK_URL=
INTEGRATION_WEBHOOK_SECRET=
